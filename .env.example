# ===== הצוות של ראובן — משתני סביבה (תבנית) =====
# העתק קובץ זה ל-.env ומלא את הערכים האמיתיים.
# אל תעלה את .env ל-git לעולם — הוא מכיל סודות.

# --- Anthropic (Claude) ---
# מפתח ה-API של Anthropic — משמש את כל סוכני הצוות.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# מודל ברירת המחדל לסוכנים (העדכני והחזק ביותר).
ANTHROPIC_MODEL=claude-opus-4-8

# --- יובל (עיצוב תמונות) ---
# מפתח לשירות יצירת תמונות (אם בשימוש).
IMAGE_API_KEY=

# --- חן (מחקר) ---
# מפתח לחיפוש/מחקר באינטרנט (אם בשימוש).
SEARCH_API_KEY=

# --- כללי ---
# רמת לוגים: debug | info | warn | error
LOG_LEVEL=info
